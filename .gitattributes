# Normalize text files and enforce consistent LF for source code.
* text=auto

# JavaScript/TypeScript and frontend sources
*.js   text eol=lf
*.jsx  text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.mjs  text eol=lf
*.cjs  text eol=lf
*.json text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf

# Windows scripts should keep CRLF
*.bat  text eol=crlf
*.cmd  text eol=crlf
